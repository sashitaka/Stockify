@page "/TransactionHistory"
@using Stockify.Data
@using Stockify.Business
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject DatabaseHelper DatabaseHelper
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Historique de transaction - Stockify</PageTitle>

<div class="transaction-wrapper">
    <div class="transaction-header">
        <h1>Historique des transactions</h1>
    </div>

    <div class="transaction-content">
        @if (isLoading)
        {
            <p>Chargement de l'historique...</p>
        }
        else if (transactions == null || transactions.Count == 0)
        {
            <p>Aucune transaction trouvée.</p>
        }
        else
        {
            <table class="transaction-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Ticker</th>
                        <th>Type</th>
                        <th>Montant</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in transactions)
                    {
                        string rowClass = transaction.Type.ToLower() == "buy" ? "buy" : "sell";
                        string statusClass = transaction.Type.ToLower() == "buy" ? "text-success" : "text-danger";
                        string typeLabel = transaction.Type.ToLower() == "buy" ? "Achat" : "Vente";

                        <tr class="transaction-row @rowClass">
                            <td>@transaction.Date</td>
                            <td><strong>@transaction.Stock</strong></td>
                            <td>
                                <span class="type-badge @(transaction.Type.ToLower() == "buy" ? "badge-buy" : "badge-sell")">
                                    @typeLabel
                                </span>
                            </td>
                            <td>@transaction.Montant.ToString("C")</td>
                            <td class="@statusClass">
                                @(transaction.Type.ToLower() == "buy" ? "✓ Achat" : "✓ Vente")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<Transaction> transactions = new();
    private bool isLoading = true;
    private string userId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        }

        await LoadTransactionHistory();
        isLoading = false;
    }

