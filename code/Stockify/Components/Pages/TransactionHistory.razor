@page "/TransactionHistory"
@using Stockify.Data
@using Stockify.Business
@inject DatabaseHelper DatabaseHelper
@inject UserSession CurrentUser

<PageTitle>Historique de transaction - Stockify</PageTitle>

<div class="transaction-wrapper">
    <div class="transaction-header">
        <h1>Historique des transactions</h1>
    </div>

    <div class="transaction-content">
        @if (isLoading)
        {
            <p>Chargement de l'historique...</p>
        }
        else if (transactions == null || transactions.Count == 0)
        {
            <p>Aucune transaction trouvée.</p>
        }
        else
        {
            <table class="transaction-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Ticker</th>
                        <th>Type</th>
                        <th>Quantité</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in transactions)
                    {
                        string rowClass = transaction.TransacType.ToLower() == "buy" ? "buy" : "sell";
                        string statusClass = transaction.TransacType.ToLower() == "buy" ? "text-success" : "text-danger";
                        string typeLabel = transaction.TransacType.ToLower() == "buy" ? "Achat" : "Vente";

                        <tr class="transaction-row @rowClass">
                            <td>@transaction.TransacDate.ToString("yyyy-MM-dd")</td>
                            <td><strong>@transaction.StockName</strong></td>
                            <td>
                                <span class="type-badge @(transaction.TransacType.ToLower() == "buy" ? "badge-buy" : "badge-sell")">
                                    @typeLabel
                                </span>
                            </td>
                            <td>@transaction.Quantity.ToString("F6")</td>
                            <td class="@statusClass">
                                @(transaction.TransacType.ToLower() == "buy" ? "✓ Achat" : "✓ Vente")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<TransactionViewModel> transactions = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactionHistory();
        isLoading = false;
    }

    private async Task LoadTransactionHistory()
    {
        try
        {
            if (!CurrentUser.IsLoggedIn) return;

            var history = await DatabaseHelper.GetTransactionHistory(CurrentUser.UserId);

            transactions = history.Select(t => new TransactionViewModel
            {
                TransactionID = t.TransactionID,
                StockName = t.StockName,
                TransacType = t.Type,
                Quantity = t.Quantity,
                TransacDate = t.Date
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur lors du chargement de l'historique: {ex.Message}");
        }
    }

    public class TransactionViewModel
    {
        public int TransactionID { get; set; }
        public string StockName { get; set; } = string.Empty;
        public string TransacType { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public DateTime TransacDate { get; set; }
    }
}