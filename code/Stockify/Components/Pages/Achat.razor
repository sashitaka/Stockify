@page "/achat/{Symbol}"
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject DatabaseHelper DB
@inject UserSession Session
@using Stockify.Data
@using Stockify.Business

<div class="home-wrapper">
    <div class="stock-card">
        <div class="stock-header">
            <h2 class="stock-ticker">Acheter @Symbol</h2>
            <div class="stock-price">@currentPrice.ToString("C2")</div>
        </div>

        <p class="auth-subtitle" style="text-align: left; margin-bottom: 20px;">
            Solde disponible: <span style="color: #00c853; font-weight: bold;">@userBalance.ToString("C2")</span>
        </p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        <div class="form-group">
            <label>Mode de calcul</label>
            <select @bind="isBuyingByAmount" class="form-group input" style="background: #2a2a2a; width: 100%; cursor: pointer;">
                <option value="true">Acheter par Montant ($)</option>
                <option value="false">Acheter par Quantité (Actions)</option>
            </select>
        </div>

        <div class="form-group">
            <label>@(isBuyingByAmount ? "Combien voulez-vous investir ?" : "Nombre d'actions à acheter")</label>
            <input type="number" step="0.01" @bind="inputValue" @bind:event="oninput" placeholder="0.00" />
        </div>

        <div class="stock-details" style="margin-top: 20px; margin-bottom: 20px;">
            <div class="detail-item">
                <span class="detail-label">Estimation</span>
                <span class="detail-value">@GetEstimation()</span>
            </div>
            <div class="detail-item">
                <span class="detail-label">Total Frais</span>
                <span class="detail-value">$0.00</span>
            </div>
        </div>

        <button class="btn-primary" @onclick="ConfirmPurchase" disabled="@isProcessing">
            @(isProcessing ? "Transaction en cours..." : "Confirmer l'achat")
        </button>

        <button class="btn-secondary" style="margin-top: 10px;" @onclick='() => Navigation.NavigateTo("/")'>
            Annuler
        </button>
    </div>
</div>

@code {
    [Parameter] public string Symbol { get; set; } = "";

    private decimal currentPrice = 0m;
    private decimal userBalance = 0m;
    private decimal inputValue;
    private bool isBuyingByAmount = true;
    private bool isProcessing = false;
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;
    private StockResult? stockData;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        // Charger le prix du stock
        var api = ApiManagerSingleton.getInstance(Configuration);
        stockData = await api.GetStockAsync(Symbol);
        if (stockData != null)
            currentPrice = (decimal)stockData.Close;

        // Charger le solde de l'utilisateur connecté
        if (Session.IsLoggedIn)
            userBalance = await DB.GetBalance(Session.UserId);

        isLoading = false;
    }

    private string GetEstimation()
    {
        if (inputValue <= 0) return isBuyingByAmount ? "0 actions" : "$0.00";

        if (isBuyingByAmount)
        {
            decimal shares = currentPrice > 0 ? inputValue / currentPrice : 0;
            return $"{shares:F6} actions";
        }
        else
        {
            decimal cost = inputValue * currentPrice;
            return cost.ToString("C2");
        }
    }

    private async Task ConfirmPurchase()
    {
        errorMessage = "";
        successMessage = "";

        if (!Session.IsLoggedIn)
        {
            errorMessage = "Vous devez être connecté pour acheter.";
            return;
        }

        decimal totalCost = isBuyingByAmount ? inputValue : (inputValue * currentPrice);
        decimal totalQuantity = isBuyingByAmount ? (currentPrice > 0 ? inputValue / currentPrice : 0) : inputValue;

        if (totalCost <= 0)
        {
            errorMessage = "Veuillez entrer un montant valide.";
            return;
        }

        if (totalCost > userBalance)
        {
            errorMessage = "Solde insuffisant pour cet achat.";
            return;
        }

        isProcessing = true;

        (bool success, string message) = await DB.BuyStock(Session.UserId, Symbol, totalQuantity, totalCost);

        if (success)
        {
            successMessage = message;
            userBalance = await DB.GetBalance(Session.UserId);
            await Task.Delay(1500);
            Navigation.NavigateTo("/portfolio");
        }
        else
        {
            errorMessage = message;
        }

        isProcessing = false;
    }
}