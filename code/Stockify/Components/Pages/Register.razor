@page "/register"
@inject NavigationManager Navigation

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">Stockify</h2>
        <p class="auth-subtitle">Créer un compte</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }

        <div class="form-group">
            <label>Nom d'utilisateur</label>
            <input @bind="username" type="text" placeholder="JohnDoe" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input @bind="email" type="email" placeholder="exemple@email.com" />
        </div>

        <div class="form-group">
            <label>Téléphone</label>
            <input @bind="phone" type="text" placeholder="514-000-0000" />
        </div>

        <div class="form-group">
            <label>Mot de passe</label>
            <input @bind="password" type="password" placeholder="••••••••" />
        </div>

        <div class="form-group">
            <label>Confirmer mot de passe</label>
            <input @bind="confirmPassword" type="password" placeholder="••••••••" />
        </div>

        <button class="btn-primary" @onclick="HandleRegister">Créer le compte</button>

        <p class="auth-footer">
            Déjà un compte? <a href="/login">Se connecter</a>
        </p>
    </div>
</div>

@code {
    private string username = "";
    private string email = "";
    private string phone = "";
    private string password = "";
    private string confirmPassword = "";
    private string errorMessage = "";

    private void HandleRegister()
    {
        if (string.IsNullOrEmpty(username) || string.IsNullOrEmpty(email) ||
            string.IsNullOrEmpty(password) || string.IsNullOrEmpty(confirmPassword))
        {
            errorMessage = "Veuillez remplir tous les champs.";
            return;
        }

        if (password != confirmPassword)
        {
            errorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }

        if (password.Length < 6)
        {
            errorMessage = "Le mot de passe doit contenir au moins 6 caractères.";
            return;
        }

        Navigation.NavigateTo("/login");
    }
}
