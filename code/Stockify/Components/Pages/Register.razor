@page "/register"
@using Stockify.Data
@inject DatabaseHelper DB
@inject NavigationManager Nav

<h3>Créer un compte</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card p-4" style="max-width: 400px; margin: auto;">
    <div class="mb-3">
        <label>Nom</label>
        <input type="text" class="form-control" @bind="name" />
    </div>
    <div class="mb-3">
        <label>Courriel</label>
        <input type="email" class="form-control" @bind="email" />
    </div>
    <div class="mb-3">
        <label>Mot de passe</label>
        <input type="password" class="form-control" @bind="password" />
    </div>
    <div class="mb-3">
        <label>Confirmer le mot de passe</label>
        <input type="password" class="form-control" @bind="confirmPassword" />
    </div>
    <button class="btn btn-primary w-100" @onclick="HandleRegister">Créer le compte</button>
    <hr />
    <a href="/login">Déjà un compte ? Se connecter</a>
</div>

@code {
    private string name = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private string successMessage = "";

    private async Task HandleRegister()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Tous les champs sont obligatoires.";
            return;
        }

        if (password != confirmPassword)
        {
            errorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }

        (bool success, string message) = await DB.Register(name, email, password);

        if (success)
        {
            successMessage = "Compte créé avec succès !";
            await Task.Delay(1500);
            Nav.NavigateTo("/login");
        }
        else
        {
            errorMessage = message;
        }
    }
}