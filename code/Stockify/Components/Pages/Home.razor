@page "/"
@using Stockify.Models
@using System.Text.Json
@inject IConfiguration Configuration

<PageTitle>Home</PageTitle>
<div class="container">
    <h3>Stock Market Search</h3>

    <div class="input-group mb-3">
        <input @bind="symbol" class="form-control" placeholder="Enter Ticker (e.g. AAPL)" />
        <button class="btn btn-primary" @onclick="FetchStock">Search</button>
    </div>

    @if (debugMessage != null)
    {
        <div class="alert alert-info">@debugMessage</div>
    }

    @if (isLoading)
    {
        <p><em>Loading data from Massive.com...</em></p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <strong>Error:</strong> @errorMessage
        </div>
        @if (!string.IsNullOrEmpty(rawJsonResponse))
        {
            <details>
                <summary>Raw API Response (Debug)</summary>
                <pre>@rawJsonResponse</pre>
            </details>
        }
    }
    else if (currentStock != null)
    {
        <div class="card mt-3" style="width: 18rem;">
            <div class="card-body">
                <h5 class="card-title text-uppercase">@currentStock.Nom</h5>
                <h6 class="card-subtitle mb-2 text-muted">Real-time Price</h6>
                <p class="card-text fs-2 fw-bold">@currentStock.Value.ToString("C")</p>

            </div>
        </div>
    }
</div>

@code {
    private string symbol = "";
    private Stock? currentStock;
    private bool isLoading = false;
    private string? errorMessage;
    private string? rawJsonResponse;
    private string? debugMessage;

    public async Task FetchStock()
    {
        debugMessage = $"🔍 Searching for {symbol}...";
        System.Diagnostics.Debug.WriteLine(debugMessage);

        if (string.IsNullOrWhiteSpace(symbol))
        {
            debugMessage = "❌ Please enter a ticker symbol";
            return;
        }

        isLoading = true;
        currentStock = null;
        errorMessage = null;
        rawJsonResponse = null;
        await Task.Delay(100); // Force UI update
        StateHasChanged();

        try
        {
            debugMessage = "⏳ Calling API...";
            System.Diagnostics.Debug.WriteLine(debugMessage);
            StateHasChanged();

            var apiManager = ApiManagerSingleton.getInstance(Configuration);
            string jsonResponse = await apiManager.GetStockValueAsync(symbol.ToUpper());

            rawJsonResponse = jsonResponse;
            System.Diagnostics.Debug.WriteLine($"Raw API Response: {jsonResponse}");

            if (jsonResponse.StartsWith("Exception:") || string.IsNullOrEmpty(jsonResponse))
            {
                errorMessage = jsonResponse ?? "Empty response from API";
                debugMessage = $"❌ API Error: {errorMessage}";
                System.Diagnostics.Debug.WriteLine(debugMessage);
                return;
            }

            try
            {
                currentStock = JsonSerializer.Deserialize<Stock>(jsonResponse,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (currentStock == null)
                {
                    errorMessage = $"Unable to parse stock data. Response: {jsonResponse.Substring(0, Math.Min(200, jsonResponse.Length))}";
                    debugMessage = $"❌ Parse Error: {errorMessage}";
                    System.Diagnostics.Debug.WriteLine(debugMessage);
                }
                else
                {
                    debugMessage = $"✅ Success! {currentStock.Nom} @ ${currentStock.Value}";
                    System.Diagnostics.Debug.WriteLine(debugMessage);
                }
            }
            catch (JsonException jex)
            {
                errorMessage = $"JSON Parse Error: {jex.Message}";
                debugMessage = $"❌ JSON Error: {errorMessage}";
                System.Diagnostics.Debug.WriteLine(debugMessage);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            debugMessage = $"💥 Exception: {ex.Message}";
            System.Diagnostics.Debug.WriteLine(debugMessage);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
 