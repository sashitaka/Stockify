@page "/"
@using Stockify.Models
@using System.Text.Json
@inject IConfiguration Configuration
@inject ApiManagerSingleton ApiManager

<PageTitle>Home</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h3 class="mb-4 text-primary">Stock Market Search</h3>
        
        <div class="input-group mb-3">
            @* Added 'onkeyup' to allow searching by pressing Enter *@
            <input type="text"
                   class="form-control"
                   @bind="searchTicker"
                   @bind:event="oninput"
                   @onkeyup="@(e => e.Key == "Enter" ? SearchStock() : null)"
                   placeholder="Enter Ticker (e.g. AAPL)" />
            <button class="btn btn-primary" @onclick="SearchStock">
                <i class="bi bi-search"></i> Search
            </button>
        </div>

        <hr />

        @if (isLoading)
        {
            <div class="text-center my-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (currentStock != null)
        {
            <div class="card border-primary mb-3">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">@currentStock.Ticker</h5>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@currentStock.Name</h5>
                    <p class="card-text">
                        <span class="badge bg-secondary">@currentStock.PrimaryExchange</span>
                        <span class="badge bg-info text-dark">@currentStock.Market</span>
                    </p>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Currency:</strong> @currentStock.CurrencyName.ToUpper()</li>
                        <li class="list-group-item">
                            <strong>Status:</strong>
                            <span class="@(currentStock.Active ? "text-success" : "text-danger")">
                                @(currentStock.Active ? "● Active" : "○ Inactive")
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        }
        else if (hasSearched)
        {
            <div class="alert alert-warning">
                No stock found for ticker "<strong>@searchTicker</strong>".
            </div>
        }
    </div>
</div>

@code {
    private string searchTicker = "";
    private Stock? currentStock;
    private bool isLoading = false;
    private bool hasSearched = false;

    private async Task SearchStock()
    {
        if (string.IsNullOrWhiteSpace(searchTicker)) return;

        isLoading = true;
        hasSearched = true;
        
        // Reset previous result before fetching new one
        currentStock = null;
        
        currentStock = await ApiManager.GetStockDetailsAsync(searchTicker);
        isLoading = false;
    }
}