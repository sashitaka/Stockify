@page "/"
@rendermode InteractiveServer
@using Stockify.Business
@inject IConfiguration Configuration
@inject ApiManagerSingleton ApiManager

<PageTitle>Stockify</PageTitle>

<div class="home-wrapper">
    <div class="search-section">
        <h2 class="search-title">Rechercher un titre</h2>
        <div class="search-bar">
            <input @bind="symbol" @bind:event="oninput"
                   @onkeypress="HandleKeyPress"
                   placeholder="Ex: AAPL, TSLA, MSFT..." />
            <button @onclick="FetchStock">Rechercher</button>
        </div>
    </div>

    @if (isLoading)
    {
        <p style="color:white;">Chargement...</p>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-box">@errorMessage</div>
    }
    else if (stock != null)
    {
        <div class="stock-card">
            <div class="stock-header">
                <h2 class="stock-ticker">@stock.Ticker</h2>
                <span class="stock-price">$@stock.Close.ToString("F2")</span>
            </div>
            <div class="stock-change @(stock.Close >= stock.Open ? "positive" : "negative")">
                @(stock.Close >= stock.Open ? "▲" : "▼")
                @((stock.Close - stock.Open).ToString("F2"))
                (@(((stock.Close - stock.Open) / stock.Open * 100).ToString("F2"))%)
            </div>
            <div class="stock-details">
                <div class="detail-item">
                    <span class="detail-label">Ouverture</span>
                    <span class="detail-value">$@stock.Open.ToString("F2")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Haut</span>
                    <span class="detail-value">$@stock.High.ToString("F2")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Bas</span>
                    <span class="detail-value">$@stock.Low.ToString("F2")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Fermeture</span>
                    <span class="detail-value">$@stock.Close.ToString("F2")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Volume</span>
                    <span class="detail-value">@stock.Volume.ToString("N0")</span>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Prix moyen</span>
                    <span class="detail-value">$@stock.VWAP.ToString("F2")</span>
                </div>

                <div class="detail-item">
                    <NavLink class="detail-value" href="@($"/achat/{stock.Ticker}")">
                        Achat
                    </NavLink>
                </div>

                <div class="detail-item">
                    <NavLink class="detail-value" href="@($"/sell/{stock.Ticker}")">
                        Vente
                    </NavLink>
                </div>

            </div>
        </div>
    }
</div>

@code {
    private string symbol = "";
    private StockResult? stock;
    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await FetchStock();
    }

    private async Task FetchStock()
    {
        if (string.IsNullOrWhiteSpace(symbol))
        {
            errorMessage = "Veuillez entrer un symbole.";
            return;
        }

        isLoading = true;
        stock = null;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var api = ApiManagerSingleton.getInstance(Configuration);
            stock = await api.GetStockAsync(symbol);

            if (stock == null)
                errorMessage = $"Aucun résultat pour '{symbol}'.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}