@page "/"
@using Stockify.Models
@using System.Text.Json

<PageTitle>Home</PageTitle>
<div class="container">
    <h3>Stock Market Search</h3>

    <div class="input-group mb-3">
        <input @bind="symbol" class="form-control" placeholder="Enter Ticker (e.g. AAPL)" />
        <button class="btn btn-primary" @onclick="FetchStock">Search</button>
    </div>

    @if (isLoading)
    {
        <p><em>Loading data from Massive.com...</em></p>
    }
    else if (currentStock != null)
    {
        <div class="card mt-3" style="width: 18rem;">
            <div class="card-body">
                <h5 class="card-title text-uppercase">@currentStock.Nom</h5>
                <h6 class="card-subtitle mb-2 text-muted">Real-time Price</h6>
                <p class="card-text fs-2 fw-bold">@currentStock.Value.ToString("C")</p>

            </div>
        </div>
    }
</div>

@code {
    private string symbol = "";
    private Stock? currentStock; // Added ? because it starts as null
    private bool isLoading = false;

    private async Task FetchStock()
    {
        if (string.IsNullOrWhiteSpace(symbol)) return;

        isLoading = true;
        currentStock = null;

        try
        {
            // 1. Get the Singleton instance
            var apiManager = ApiManagerSingleton.getInstance();

            // 2. AWAIT the call to get the raw JSON string
            string jsonResponse = await apiManager.GetStockValueAsync(symbol);

            // 3. Convert the JSON string into your 'Stock' object
            // Note: PropertyNameCaseInsensitive helps if the API uses "value" instead of "Value"
            currentStock = JsonSerializer.Deserialize<Stock>(jsonResponse,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch (Exception ex)
        {
            // If the ticker is wrong or the API is down, we handle it here
            Console.WriteLine($"Error fetching stock: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            // StateHasChanged tells Blazor to refresh the UI immediately
            StateHasChanged();
        }
    }
}
 