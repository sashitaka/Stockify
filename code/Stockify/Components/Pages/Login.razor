@page "/login"
@inject NavigationManager Navigation
@using Data

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">Stockify</h2>
        <p class="auth-subtitle">Connectez-vous à votre compte</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }

        <div class="form-group">
            <label>Email</label>
            <input @bind="email" type="email" placeholder="exemple@email.com" />
        </div>

        <div class="form-group">
            <label>Mot de passe</label>
            <input @bind="password" type="password" placeholder="••••••••" />
        </div>

        <button class="btn-primary" @onclick="HandleLogin">Se connecter</button>

        <p class="auth-footer">
            Pas de compte? <a href="/register">Créer un compte</a>
        </p>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password))
        {
            errorMessage = "Veuillez remplir tous les champs.";
            return;
        }

        var db = new DatabaseHelper();
        bool isValidUser = await db.Login(email, password);
        if (isValidUser)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = "Email ou mot de passe incorrect.";
        }

    }
}