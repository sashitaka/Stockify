@page "/login"
@inject NavigationManager Navigation
@using Stockify.Data

<div class="auth-wrapper">
    <div class="auth-card">
        <h2 class="auth-title">Stockify</h2>
        <p class="auth-subtitle">Connectez-vous à votre compte</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-box">@errorMessage</div>
        }

        <div class="form-group">
            <label>Email</label>
            <input @bind="email" type="email" placeholder="exemple@email.com" />
        </div>

        <div class="form-group">
            <label>Mot de passe</label>
            <input @bind="password" type="password" placeholder="••••••••" />
        </div>

        <button class="btn-primary" @onclick="HandleLogin">Se connecter</button>

        <p class="auth-footer">
            Pas de compte? <a href="/register">Créer un compte</a>
        </p>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        errorMessage = "Test de connexion en cours...";
        StateHasChanged(); // Force the UI to update

        var db = new DatabaseHelper();
        var test = await db.TestConnection();

        if (!test.success)
        {
            // If this triggers, your firewall or connection string is the problem
            errorMessage = test.message;
            return;
        }

        // If the test passes, proceed to actual login
        bool isValidUser = await db.Login(email, password);
        if (isValidUser)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = "Connexion au serveur réussie, mais Email ou Mot de passe incorrect.";
        }
    }
}