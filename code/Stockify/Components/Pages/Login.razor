@page "/login"
@using Stockify.Data
@inject DatabaseHelper DB
@inject NavigationManager Nav
@inject UserSession Session

<h3>Connexion</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card p-4" style="max-width: 400px; margin: auto;">
    <div class="mb-3">
        <label>Courriel</label>
        <input type="email" class="form-control" @bind="email" />
    </div>
    <div class="mb-3">
        <label>Mot de passe</label>
        <input type="password" class="form-control" @bind="password" />
    </div>
    <button class="btn btn-primary w-100" @onclick="HandleLogin">Se connecter</button>
    <hr />
    <a href="/register">Pas de compte ? S'inscrire</a>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        errorMessage = "";
        int userId = await DB.Login(email, password);

        if (userId != -1)
        {
            Session.UserId = userId;
            Session.Name = await DB.GetUserName(userId);
            Nav.NavigateTo("/");
        }
        else
        {
            errorMessage = "Courriel ou mot de passe incorrect.";
        }
    }
}