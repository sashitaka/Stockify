@page "/portfolio"
@using Stockify.Data
@using Stockify.Business
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject DatabaseHelper DatabaseHelper
@inject ApiManagerSingleton ApiManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserSession CurrentUser

<PageTitle>Portfolio - Stockify</PageTitle>

<div class="portfolio-wrapper">
    <div class="portfolio-header">
        <h1>Mon Portfolio</h1>
    </div>

    <div class="portfolio-content">
        @if (isLoading)
        {
            <p>Chargement du portfolio...</p>
        }
        else if (portfolioItems == null || portfolioItems.Count == 0)
        {
            <p>Aucun stock dans votre portfolio.</p>
        }
        else
        {
            <table class="portfolio-table">
                <thead>
                    <tr>
                        <th>Ticker</th>
                        <th>Nom de la compagnie</th>
                        <th>Quantité</th>
                        <th>Prix moyen d'achat</th>
                        <th>Valeur d'achat totale</th>
                        <th>Valeur actuelle</th>
                        <th>Valeur totale actuelle</th>
                        <th>Profit/Déficit %</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in portfolioItems)
                    {
                        decimal itemValue = (decimal)item.QuantityOwned * item.CurrentPrice;
                        decimal averageCost = item.QuantityOwned > 0 ? (decimal)item.OwnedValue / (decimal)item.QuantityOwned : 0;
                        decimal profit = itemValue - (decimal)item.OwnedValue;
                        decimal profitPercentage = item.OwnedValue > 0 ? (profit / (decimal)item.OwnedValue) * 100 : 0;
                        string rowClass = profitPercentage >= 0 ? "profit" : "deficit";

                        <tr class="portfolio-stock @rowClass">
                            <td><strong>@item.Ticker</strong></td>
                            <td>@item.Name</td>
                            <td>@item.QuantityOwned.ToString("F2")</td>
                            <td>@averageCost.ToString("C")</td>
                            <td>@item.OwnedValue.ToString("C")</td>
                            <td>@item.CurrentPrice.ToString("C")</td>
                            <td>@itemValue.ToString("C")</td>
                            <td class="@(profitPercentage >= 0 ? "text-success" : "text-danger")">
                                @profitPercentage.ToString("F2")%
                            </td>
                        </tr>
                    }
                    @{
                        string totalRowClass = globalPercentage >= 0 ? "profit" : "deficit";
                    }
                    <tr class="portfolio-total @totalRowClass">
                        <td colspan="4"><strong>Total</strong></td>
                        <td><strong>@portfolioItems.Sum(p => (decimal)p.OwnedValue).ToString("C")</strong></td>
                        <td></td>
                        <td><strong>@totalValue.ToString("C")</strong></td>
                        <td class="@(globalPercentage >= 0 ? "text-success" : "text-danger")">
                            <strong>@globalPercentage.ToString("F2")%</strong>
                        </td>
                    </tr>
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<PortfolioItemViewModel> portfolioItems = new();
    private bool isLoading = true;
    private decimal totalValue = 0;
    private decimal globalPercentage = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            if (CurrentUser.IsLoggedIn)
            {
                int userId = CurrentUser.UserId;

                if (userId != -1)
                {
                    // 2. Fetch user stocks from the database
                    // Assuming DatabaseHelper.GetPortfolio(userId) returns a list of your stock objects
                    var userStocks = await DatabaseHelper.GetPortfolio(userId);

                    foreach (var stock in userStocks)
                    {
                        // 3. Fetch real-time price from your ApiManager
                        // Assuming GetCurrentPrice returns a decimal or float
                        //var currentPrice = await ApiManager.GetStockAsync(stock.Ticker);

                        portfolioItems.Add(new PortfolioItemViewModel
                        {
                            Name = stock.StockName,
                            QuantityOwned = stock.Quantity,
                            //OwnedValue = currentPrice * (decimal)stock.Quantity, // Total cost basis
                            //CurrentPrice = (decimal)currentPrice
                        });
                    }

                    CalculateTotals();
                }
            }
        }
        catch (Exception ex)
        {
            // Log error appropriately
            Console.WriteLine($"Error loading portfolio: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateTotals()
    {
        decimal totalCostBasis = portfolioItems.Sum(item => (decimal)item.OwnedValue);
        totalValue = portfolioItems.Sum(item => (decimal)item.QuantityOwned * item.CurrentPrice);

        if (totalCostBasis > 0)
        {
            globalPercentage = ((totalValue - totalCostBasis) / totalCostBasis) * 100;
        }
    }

    // Helper class to hold merged data for the UI
    public class PortfolioItemViewModel
    {
        public string Ticker { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public float QuantityOwned { get; set; }
        public float OwnedValue { get; set; } // Your purchase cost
        public decimal CurrentPrice { get; set; }
    }
}



