@page "/portfolio"
@using Stockify.Data
@using Stockify.Business
@inject DatabaseHelper DatabaseHelper
@inject UserSession CurrentUser
@inject IConfiguration Configuration

<PageTitle>Portfolio - Stockify</PageTitle>

<div class="portfolio-wrapper">
    <div class="portfolio-header">
        <h1>Mon Portfolio</h1>
    </div>

    <div class="portfolio-content">
        @if (isLoading)
        {
            <p>Chargement du portfolio...</p>
        }
        else if (portfolioItems == null || portfolioItems.Count == 0)
        {
            <p>Aucun stock dans votre portfolio.</p>
        }
        else
        {
            <table class="portfolio-table">
                <thead>
                    <tr>
                        <th>Ticker</th>
                        <th>Nom de la compagnie</th>
                        <th>Quantité</th>
                        <th>Valeur actuelle du Stock</th>
                        <th>Valeur totale actuelle possédée</th>
                        <th>Profit/Déficit %</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in portfolioItems)
                    {
                        double itemValue = item.QuantityOwned * item.CurrentPrice;
                        double profit = itemValue - item.OwnedValue;
                        double profitPercentage = item.OwnedValue > 0 ? (profit / item.OwnedValue) * 100 : 0;

                        <tr class="portfolio-stock">
                            <td><strong>@item.Ticker</strong></td>
                            <td>@item.Name</td>
                            <td>@item.QuantityOwned.ToString("F2")</td>
                            <td>@item.CurrentPrice.ToString("C")</td>
                            <td>@itemValue.ToString("C")</td>
                            <td class="@(profitPercentage >= 0 ? "text-success" : "text-danger")">
                                @profitPercentage.ToString("F2")%
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<PortfolioItemViewModel> portfolioItems = new();
    private bool isLoading = true;
    private decimal totalValue = 0;
    private decimal globalPercentage = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Attendre que SessionInitializer ait le temps de charger
            await Task.Delay(300);

            if (CurrentUser.IsLoggedIn)
            {
                await LoadPortfolio();
                StateHasChanged();
            }
            else
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadPortfolio()
    {
        var api = ApiManagerSingleton.getInstance(Configuration);
        try
        {
            isLoading = true;
            portfolioItems.Clear();

            var userStocks = await DatabaseHelper.GetPortfolio(CurrentUser.UserId);

            foreach (var stock in userStocks)
            {
                var stockData = await api.GetStockAsync(stock.StockName);

                double currentPrice = stockData?.Close ?? 0;
                string ticker = stock.StockName;
                string companyName = stockData?.Ticker ?? stock.StockName;

                portfolioItems.Add(new PortfolioItemViewModel
                {
                    Ticker = ticker,
                    Name = companyName,
                    QuantityOwned = (double)stock.Quantity,
                    CurrentPrice = currentPrice,
                    OwnedValue = currentPrice * (double)stock.Quantity
                });
            }

            CalculateTotals();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading portfolio: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateTotals()
    {
        decimal totalCostBasis = portfolioItems.Sum(item => (decimal)item.OwnedValue);
        totalValue = portfolioItems.Sum(item => (decimal)(item.QuantityOwned * item.CurrentPrice));

        if (totalCostBasis > 0)
            globalPercentage = ((totalValue - totalCostBasis) / totalCostBasis) * 100;
    }

    public class PortfolioItemViewModel
    {
        public string Ticker { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public double QuantityOwned { get; set; }
        public double OwnedValue { get; set; }
        public double CurrentPrice { get; set; }
    }
}